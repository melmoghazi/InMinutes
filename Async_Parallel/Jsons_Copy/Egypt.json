{
  "Egypt": {
    "Name_En": "Egypt",
    "Name_AR": "مصر",
    "Language": "Arabic",
    "History": "Egypt, known as the 'Gift of the Nile,' has a history that spans over 5,000 years. It is one of the world's oldest civilizations, with ancient landmarks such as the Pyramids of Giza, the Sphinx, and the temples of Luxor. Egypt has been a center of culture, politics, and commerce throughout history, influencing neighboring regions and leaving a lasting legacy in art, architecture, and science.",
    "cities": [
      {
        "City_En": "Cairo",
        "City_AR": "القاهرة",
        "History": "Cairo, the capital of Egypt, has a rich history dating back to its founding in 969 AD by the Fatimid dynasty. It has been a center of culture, politics, and commerce for centuries, with landmarks such as the Pyramids of Giza and the Egyptian Museum showcasing its ancient heritage."
      },
      {
        "City_En": "Alexandria",
        "City_AR": "الإسكندرية",
        "History": "Alexandria, founded by Alexander the Great in 331 BC, is a historic city on the Mediterranean coast. It was once a major center of learning and culture in the ancient world, home to the famous Library of Alexandria and the Lighthouse of Alexandria, one of the Seven Wonders of the Ancient World."
      },
      {
        "City_En": "Giza",
        "City_AR": "الجيزة",
        "History": "Giza is renowned for its ancient monuments, including the Great Pyramid of Giza, one of the Seven Wonders of the Ancient World, and the Great Sphinx."
      },
      {
        "City_En": "Shubra El-Kheima",
        "City_AR": "شبرا الخيمة",
        "History": "Shubra El-Kheima is a major industrial city in Egypt, known for its factories and proximity to Cairo."
      },
      {
        "City_En": "Port Said",
        "City_AR": "بورسعيد",
        "History": "Port Said is a port city at the northern end of the Suez Canal, known for its strategic importance and free trade zone."
      },
      {
        "City_En": "Suez",
        "City_AR": "السويس",
        "History": "Suez is a city at the southern end of the Suez Canal, playing a vital role in global maritime trade."
      },
      {
        "City_En": "Luxor",
        "City_AR": "الأقصر",
        "History": "Luxor is often referred to as the world's greatest open-air museum, with its temples and tombs from ancient Thebes."
      },
      {
        "City_En": "Al-Mansura",
        "City_AR": "المنصورة",
        "History": "Al-Mansura is known for its historical significance in the Battle of Mansura during the Crusades."
